# Client environment variables
# Copy to .env for local overrides. Only VITE_-prefixed vars reach the browser.

# Base URL for the API. Leave empty in development — the Vite dev server
# proxies /api requests to the Express server (see vite.config.ts).
VITE_API_URL=

# Set to "true" only in the public read-only demo deployment. Leave unset
# (or "false") everywhere else, including local dev. Switches the app to a
# fully static build with no backend at all: reads come from
# lib/mockData.ts instead of a real API, and every write is rejected with
# the same message a real backend would give. See lib/demo.ts, lib/api.ts,
# lib/mockApi.ts, and docs/deploying-the-demo.md.
VITE_DEMO_MODE=
