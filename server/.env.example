# Server environment variables
# Copy to .env and adjust. The server validates these at startup (src/config/env.ts)
# and refuses to boot with invalid configuration.

NODE_ENV=development
PORT=3000
CLIENT_ORIGIN=http://localhost:5173

# Matches docker-compose.yml. Local dev credentials only — production uses real secrets.
DATABASE_URL=postgresql://ever_after:ever_after_dev@localhost:5433/ever_after

# How long a login lasts before requiring re-authentication.
SESSION_TTL_DAYS=30

# Set to "true" only in the public read-only demo deployment. Every request
# auto-authenticates as one fixed, viewer-only account (see lib/demo.ts,
# middleware/auth.ts), and every write is rejected before it reaches a route
# (see app.ts). Leave "false" everywhere else, including local dev against
# real wedding data — this is a separate deployment with its own database,
# never a mode you flip on your own data.
DEMO_MODE=false
