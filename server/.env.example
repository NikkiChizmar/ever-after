# Server environment variables
# Copy to .env and adjust. The server validates these at startup (src/config/env.ts)
# and refuses to boot with invalid configuration.

NODE_ENV=development
PORT=3000
CLIENT_ORIGIN=http://localhost:5173

# Matches docker-compose.yml. Local dev credentials only — production uses real secrets.
DATABASE_URL=postgresql://ever_after:ever_after_dev@localhost:5433/ever_after

# How long a login lasts before requiring re-authentication.
SESSION_TTL_DAYS=30
